<Window x:Class="ClaudeTray.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="claude-tray settings" SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="18">
        <TextBlock Text="Alerts" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <DockPanel Margin="0,2">
            <TextBlock Text="Alert threshold" Width="160" VerticalAlignment="Center"/>
            <TextBlock x:Name="ThresholdLabel" DockPanel.Dock="Right" Width="42" TextAlignment="Right"
                       VerticalAlignment="Center"/>
            <Slider x:Name="ThresholdSlider" Minimum="50" Maximum="99" TickFrequency="5"
                    IsSnapToTickEnabled="False" ValueChanged="Threshold_Changed"/>
        </DockPanel>
        <CheckBox x:Name="NotifyThresholdBox" Content="Notify when a limit crosses the threshold" Margin="0,4"/>
        <CheckBox x:Name="NotifyExceededBox" Content="Notify when a limit reaches 100%" Margin="0,4"/>
        <CheckBox x:Name="NotifyResetBox" Content="Notify when a limit window resets" Margin="0,4"/>
        <CheckBox x:Name="MuteAllBox" Content="Mute all notifications" Margin="0,4"/>

        <TextBlock Text="Per-limit notifications" FontWeight="SemiBold" Margin="0,12,0,4"/>
        <ItemsControl x:Name="BucketList"/>
        <TextBlock x:Name="NoBucketsText" Text="(buckets appear after the first successful poll)"
                   Foreground="Gray" FontSize="11"/>

        <TextBlock Text="Polling" FontWeight="SemiBold" Margin="0,12,0,6"/>
        <DockPanel Margin="0,2">
            <TextBlock Text="Poll interval (seconds)" Width="160" VerticalAlignment="Center"/>
            <TextBlock x:Name="IntervalLabel" DockPanel.Dock="Right" Width="42" TextAlignment="Right"
                       VerticalAlignment="Center"/>
            <Slider x:Name="IntervalSlider" Minimum="10" Maximum="600" TickFrequency="10"
                    ValueChanged="Interval_Changed"/>
        </DockPanel>

        <TextBlock Text="General" FontWeight="SemiBold" Margin="0,12,0,6"/>
        <CheckBox x:Name="StartupBox" Content="Start with Windows" Margin="0,4"/>
        <CheckBox x:Name="UpdatesBox" Content="Check for updates daily" Margin="0,4"/>

        <DockPanel Margin="0,16,0,0">
            <Button x:Name="SignOutButton" Content="Sign out" Click="SignOut_Click" Padding="10,4"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Save" Click="Save_Click" Padding="16,4" FontWeight="SemiBold"/>
            </StackPanel>
        </DockPanel>
        <TextBlock x:Name="VersionText" Foreground="Gray" FontSize="10.5" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
